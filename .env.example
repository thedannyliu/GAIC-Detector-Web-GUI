# Environment Configuration for GAIC Detector

# API Server Settings
API_HOST=0.0.0.0
API_PORT=8000

# LLM Settings (Optional - for report generation)
LLM_ENABLED=false
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-3.5-turbo

# Model Settings
# Add custom model paths if needed
# MODEL_PATH_SUSY=models/weights/susy.pth
# MODEL_PATH_FATFORMER=models/weights/fatformer.pth
# MODEL_PATH_DISTILDIRE=models/weights/distildire.pth

# Processing Settings
# MAX_FILE_SIZE_MB=10
# MAX_LONG_SIDE=1536
# TIMEOUT_TOTAL=40

# Development Settings
DEBUG=false
LOG_LEVEL=INFO
