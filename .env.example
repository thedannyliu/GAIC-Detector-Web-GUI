# Environment Configuration for GAIC Detector
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ── Server settings ─────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Gemini API (required for AI-generated analysis reports) ─────
# Get a free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Gradio share link (for cluster use) ─────────────────────────
# Set to true to generate a public Gradio share URL instead of using
# SSH tunnel (useful when direct port forwarding is not available).
GRADIO_SHARE=false

# ── Optional overrides ───────────────────────────────────────────
# GAIC_BACKEND_URL=http://localhost:8000
# LOG_LEVEL=INFO
